<idea-plugin>
    <id>com.github.benjamin_thomas.intellij_rescript</id>
    <name>ReScript</name>
    <vendor url="https://github.com/benjamin-thomas/intellij-rescript">benjamin-thomas</vendor>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <description><![CDATA[
        ReScript language support for JetBrains IDEs.
    ]]></description>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.ReScriptFileType"
                language="ReScript"
                extensions="res"/>
        <fileType
                name="ReScript Interface"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.ReScriptInterfaceFileType"
                language="ReScript"
                extensions="resi"/>
    </extensions>
</idea-plugin>
