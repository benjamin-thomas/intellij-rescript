<idea-plugin>
    <id>com.github.benjamin_thomas.intellij_rescript</id>
    <name>ReScript IDE</name>
    <vendor url="https://github.com/benjamin-thomas/intellij-rescript">benjamin-thomas</vendor>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <description><![CDATA[
        <p>ReScript language support for JetBrains IDEs via LSP.</p>
        <p>Provides syntax highlighting, code folding, and full IDE intelligence
        (completion, hover, go-to-definition, references, rename, diagnostics,
        formatting) by integrating with the ReScript language server.</p>
        <h3>Requirements</h3>
        <ul>
            <li>Install <code>@rescript/language-server</code> globally:
                <code>npm install -g @rescript/language-server</code></li>
            <li>Set its executable path in <code>Languages &amp; Frameworks &gt; ReScript</code></li>
            <li>Run the ReScript compiler in watch mode in your project terminal:
                <code>npx rescript watch</code> (v12+) or
                <code>npx rescript build -w</code> (older versions)</li>
            <li>LSP4IJ plugin must be installed (required dependency)</li>
        </ul>
        <p><strong>Alpha quality.</strong> Core features work well but some constructs
        (template string interpolation, JSX) are not yet fully parsed.
        Found something that doesn't work and is not listed in the
        <a href="https://github.com/benjamin-thomas/intellij-rescript/tree/master/_tickets/todo">roadmap</a>?
        Please <a href="https://github.com/benjamin-thomas/intellij-rescript/issues">report it on GitHub</a>.</p>
    ]]></description>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="ReScript"
                fieldName="INSTANCE"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.ReScriptFileType"
                language="ReScript"
                extensions="res"/>
        <fileType
                name="ReScript Interface"
                fieldName="INSTANCE"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.ReScriptInterfaceFileType"
                language="ReScript"
                extensions="resi"/>
        <lang.syntaxHighlighterFactory
                language="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptSyntaxHighlighterFactory"/>
        <lang.parserDefinition
                language="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptParserDefinition"/>
        <lang.quoteHandler
                language="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptQuoteHandler"/>
        <gotoRelatedProvider
                implementation="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptGotoRelatedProvider"/>
        <lang.braceMatcher
                language="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptBraceMatcher"/>
        <lang.commenter
                language="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptCommenter"/>
        <lang.foldingBuilder
                language="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptFoldingBuilder"/>
        <lang.psiStructureViewFactory
                language="ReScript"
                implementationClass="com.redhat.devtools.lsp4ij.features.documentSymbol.LSPDocumentSymbolStructureViewFactory"/>
        <!-- LSP4IJ's built-in handler truncates the signature (drops closing paren + return type).
             Our handler renders the complete label from the LSP signatureHelp response. -->
        <codeInsight.parameterInfo
                language="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lsp.ReScriptParameterInfoHandler"/>
        <!-- ReScript LSP server does not support callHierarchyProvider
        <callHierarchyProvider
                language="ReScript"
                implementationClass="com.redhat.devtools.lsp4ij.features.callHierarchy.LSPCallHierarchyProvider"/>
        -->
        
        <spellchecker.support
                language="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptSpellcheckingStrategy"/>

        <breadcrumbsInfoProvider
                implementation="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptBreadcrumbsProvider"/>

        <lang.inspectionSuppressor
                language="ReScript"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptInspectionSuppressor"/>

        <lang.elementManipulator
                forClass="com.github.benjamin_thomas.intellij_rescript.lang.psi.ReScriptStringLiteral"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.psi.ReScriptStringLiteralManipulator"/>
        <lang.elementManipulator
                forClass="com.github.benjamin_thomas.intellij_rescript.lang.psi.ReScriptTemplateLiteral"
                implementationClass="com.github.benjamin_thomas.intellij_rescript.lang.psi.ReScriptTemplateLiteralManipulator"/>

        <statementUpDownMover
                implementation="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptStatementMover"/>

        <projectViewNestingRulesProvider
                implementation="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptFileNestingProvider"/>

        <!--suppress PluginXmlI18n -->
        <notificationGroup id="ReScript"
                           displayType="BALLOON"/>

        <projectConfigurable
                id="language.rescript"
                displayName="ReScript"
                groupId="language"
                instance="com.github.benjamin_thomas.intellij_rescript.lsp.ReScriptLspConfigurable"/>
        <postStartupActivity implementation="com.github.benjamin_thomas.intellij_rescript.lsp.ReScriptLspStartupActivity"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="rescriptLanguageServer"
                name="ReScript Language Server"
                factoryClass="com.github.benjamin_thomas.intellij_rescript.lsp.ReScriptLanguageServerFactory">
            <description><![CDATA[
                ReScript Language Server providing hover, completion, diagnostics, and more.
            ]]></description>
        </server>
        <languageMapping language="ReScript"
                         serverId="rescriptLanguageServer"
                         languageId="rescript"/>
    </extensions>

    <actions>
        <action id="ReScript.NewFile"
                class="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptCreateFileAction"
                text="ReScript File"
                description="Create a new ReScript file">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
        </action>
    </actions>
</idea-plugin>
