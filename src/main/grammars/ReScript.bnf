{
    parserClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptParser"

    psiClassPrefix="ReScript"
    psiImplClassSuffix="Impl"
    psiPackage="com.github.benjamin_thomas.intellij_rescript.lang.psi"
    psiImplPackage="com.github.benjamin_thomas.intellij_rescript.lang.psi.impl"

    elementTypeHolderClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptTypes"
    elementTypeClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptElementType"
    tokenTypeClass="com.github.benjamin_thomas.intellij_rescript.lang.ReScriptTokenType"

    tokens = [
        // Keywords
        LET        = 'LET'
        TYPE       = 'TYPE'
        MODULE     = 'MODULE'
        OPEN       = 'OPEN'
        INCLUDE    = 'INCLUDE'
        EXTERNAL   = 'EXTERNAL'
        EXCEPTION  = 'EXCEPTION'
        REC        = 'REC'
        TRUE       = 'TRUE'
        FALSE      = 'FALSE'
        SWITCH     = 'SWITCH'
        IF         = 'IF'
        ELSE       = 'ELSE'
        ASYNC      = 'ASYNC'
        AWAIT      = 'AWAIT'
        TRY        = 'TRY'
        CATCH      = 'CATCH'
        WHILE      = 'WHILE'
        FOR        = 'FOR'
        AND        = 'AND'
        AS         = 'AS'

        // Identifiers
        LIDENT     = 'LIDENT'
        UIDENT     = 'UIDENT'

        // Literals
        BIGINT     = 'BIGINT'
        INT        = 'INT'
        FLOAT      = 'FLOAT'
        STRING_START   = 'STRING_START'
        STRING_END     = 'STRING_END'
        STRING_CONTENT = 'STRING_CONTENT'
        STRING_ESCAPE  = 'STRING_ESCAPE'
        TEMPLATE_START = 'TEMPLATE_START'
        TEMPLATE_END   = 'TEMPLATE_END'
        TEMPLATE_CONTENT  = 'TEMPLATE_CONTENT'
        REGEX          = 'REGEX'

        // Comments
        LINE_COMMENT  = 'LINE_COMMENT'
        BLOCK_COMMENT = 'BLOCK_COMMENT'

        // Multi-char operators
        AMPAMPAMP    = 'AMPAMPAMP'
        AMPAMP       = 'AMPAMP'
        PIPEPIPEPIPE = 'PIPEPIPEPIPE'
        PIPEPIPE     = 'PIPEPIPE'
        CARETCARETCARET = 'CARETCARETCARET'
        TILDETILDETILDE = 'TILDETILDETILDE'
        SHIFT_LEFT   = 'SHIFT_LEFT'
        SHIFT_RIGHT  = 'SHIFT_RIGHT'
        SHIFT_RIGHT_UNSIGNED = 'SHIFT_RIGHT_UNSIGNED'
        STARSTAR     = 'STARSTAR'
        EQEQEQ       = 'EQEQEQ'
        BANGEQEQ     = 'BANGEQEQ'
        COLONGT      = 'COLONGT'
        DOTDOT       = 'DOTDOT'
        EQEQ         = 'EQEQ'
        BANGEQ        = 'BANGEQ'
        LTEQ          = 'LTEQ'
        GTEQ          = 'GTEQ'
        ARROW         = 'ARROW'
        FAT_ARROW     = 'FAT_ARROW'
        PIPE_FORWARD  = 'PIPE_FORWARD'
        PLUS_DOT      = 'PLUS_DOT'
        MINUS_DOT     = 'MINUS_DOT'
        STAR_DOT      = 'STAR_DOT'
        SLASH_DOT     = 'SLASH_DOT'

        // Single-char operators
        EQ         = 'EQ'
        PLUS       = 'PLUS'
        MINUS      = 'MINUS'
        STAR       = 'STAR'
        SLASH      = 'SLASH'
        LT         = 'LT'
        GT         = 'GT'

        // Delimiters
        LPAREN     = 'LPAREN'
        RPAREN     = 'RPAREN'
        LBRACE     = 'LBRACE'
        RBRACE     = 'RBRACE'
        LBRACKET   = 'LBRACKET'
        RBRACKET   = 'RBRACKET'

        // Punctuation
        COMMA      = 'COMMA'
        SEMICOLON  = 'SEMICOLON'
        COLON      = 'COLON'
        DOTDOTDOT  = 'DOTDOTDOT'
        DOT        = 'DOT'
        AT         = 'AT'
        TILDE      = 'TILDE'
        PIPE       = 'PIPE'
        UNDERSCORE = 'UNDERSCORE'
        BANG       = 'BANG'
        QUESTION   = 'QUESTION'
        HASH       = 'HASH'
        TICK       = 'TICK'
        PCT_PCT = 'PCT_PCT'
        PCT     = 'PCT'
    ]
}

// =============================================================================
// Top-level structure
//
// Naming convention (Go-like):
//   PascalCase = public rule (generates a PSI node)
//   camelCase  = private rule (no PSI node, parser-internal)
//
// Why not _underscore prefix for private rules? GrammarKit treats _-prefixed
// names specially: it ignores the `private` keyword and generates PSI nodes
// for them anyway, plus emits bogus token types. So we rely on casing alone.
//
// ADDING A NEW DECLARATION TYPE:
//   1. Add the rule to `blockDeclaration` and define the concrete rule below
//   2. Add its keyword to `declKeyword`
// That's it. Top-level recovery, brace nesting, and paren/bracket handling
// all derive from these two rules automatically.
// =============================================================================

File ::= structureItem*

// All declaration types (change 1 of 2)
private blockDeclaration ::= DecoratedDeclaration | bareDeclaration

// Declarations without decorator wrapper (used by DecoratedDeclaration)
private bareDeclaration ::= LetBinding | ModuleBinding | TypeDeclaration
                          | OpenStatement | IncludeStatement | ExternalDeclaration | ExceptionDeclaration
                          | ExtensionPoint

// Decorator + declaration wrapper: all decorators are siblings of the declaration
DecoratedDeclaration ::= Decorator+ bareDeclaration { pin = 1 }

// All declaration-starting keywords (change 2 of 2)
private declKeyword ::= LET | MODULE | TYPE | OPEN | INCLUDE | EXTERNAL | EXCEPTION

// Top-level item: a declaration or a top-level expression statement.
// Boundary detection is the same for both: a structure item runs until
// the next declaration starter or EOF.
private structureItem ::= (blockDeclaration | TopLevelExpr) { recoverWhile = structureItemRecover }
private structureItemRecover ::= !(declKeyword | AT | PCT_PCT | <<eof>>)

// Top-level expression statement: public node, opaque internals (same tokens as Expr).
// Covers switch/if/for/while/try/function-call/etc. — anything that isn't a declaration.
TopLevelExpr ::= (delimitedBlock | nonDeclToken)+

// Bindings (bind a name to a value)
// See _knowledge/parser/PSI_CUSTOMIZATION.md for how mixin + implements work.
LetBinding      ::= LET REC? LetBindingPattern (EQ Expr)? {
    pin = 1
    mixin="com.github.benjamin_thomas.intellij_rescript.lang.psi.impl.ReScriptLetBindingMixin"
    implements="com.intellij.psi.PsiNameIdentifierOwner"
}
ModuleBinding   ::= MODULE UIDENT ModuleSignature? (EQ ModuleBody)? {
    pin = 1
    mixin="com.github.benjamin_thomas.intellij_rescript.lang.psi.impl.ReScriptModuleBindingMixin"
    implements="com.intellij.psi.PsiNameIdentifierOwner"
}

// Module signature: `: { ... }` or `: ModuleName`
ModuleSignature ::= COLON (bracedBlock | UIDENT (DOT UIDENT)*) { pin = 1 }

// Module body: public node, opaque internals (same tokens as opaqueBody)
ModuleBody      ::= opaqueBody+

// Declarations
TypeDeclaration ::= TYPE REC? LIDENT TypeBody? {
    pin = 1
    mixin="com.github.benjamin_thomas.intellij_rescript.lang.psi.impl.ReScriptTypeDeclarationMixin"
    implements="com.intellij.psi.PsiNameIdentifierOwner"
}

// Type body: public node, opaque internals (same tokens as opaqueBody)
TypeBody        ::= opaqueBody+

// Statements
OpenStatement   ::= OPEN opaqueBody* { pin = 1 }
IncludeStatement ::= INCLUDE opaqueBody* { pin = 1 }

// Declarations
ExternalDeclaration  ::= EXTERNAL opaqueBody* { pin = 1 }
ExceptionDeclaration ::= EXCEPTION opaqueBody* { pin = 1 }

// Extension points (%%raw, %%private, etc.)
ExtensionPoint  ::= PCT_PCT opaqueBody* { pin = 1 }

// Decorators (@react.component, @module, @as, @val, etc.)
// The ReScript compiler allows any keyword as a decorator name (res_core.ml: parse_attribute_id).
Decorator       ::= AT decoratorName (DOT decoratorName)* parenBlock? { pin = 1 }
// Any keyword is valid as a decorator name (matches ReScript compiler behavior).
private decoratorName ::= LIDENT | UIDENT | exprKeyword | declKeyword

// =============================================================================
// Opaque body — a catch-all blob for declaration bodies we don't parse yet.
// As features demand structure, rules stop using opaqueBody and define their
// own sub-rules (e.g. LetBinding already splits into LetBindingPattern + Expr).
//
// Consumes any token, tracking delimiter depth so that nested declarations
// inside { } are recognized as proper PSI nodes rather than raw tokens.
// Inside ( ) and [ ], keywords are consumed as raw tokens — no declarations
// start inside parens/brackets in ReScript.
//
// Known limitation: opaqueBody* is greedy — a nested let binding consumes
// everything until the next let/type/module or closing brace. This means
// trailing expressions in a block (e.g. `2 + b` after `let b = 1`) get
// attached to the inner binding rather than the enclosing block.
// Fixing this requires full expression parsing (knowing where one expression
// ends and the next begins). See NestedLetBindings test fixture.
//
// ADDING A NEW TOKEN:
//   Add it to exactly one category below (exprKeyword, LIDENT/UIDENT, literal,
//   anyOperator, punctuation, or comment). If forgotten, the token will silently
//   cause parse errors inside declaration bodies.
// =============================================================================

private opaqueBody ::= delimitedBlock | nonDeclToken

private delimitedBlock ::= bracedBlock | parenBlock | bracketBlock
private bracedBlock    ::= LBRACE blockContent* RBRACE { pin = 1 }
private parenBlock     ::= LPAREN parenContent* RPAREN { pin = 1 }
private bracketBlock   ::= LBRACKET parenContent* RBRACKET { pin = 1 }

// Inside braces: nested declarations are valid.
// References blockDeclaration (not declaration) to avoid recoverWhile eating past `}`.
private blockContent ::= blockDeclaration | parenContent

// Inside parens/brackets: keywords are raw tokens, no declarations
private parenContent ::= delimitedBlock | declKeyword | AT | PCT_PCT | nonDeclToken

// All non-declaration-keyword, non-delimiter tokens
private nonDeclToken ::= exprKeyword | LIDENT | UIDENT | literal | anyOperator | punctuation | comment
private exprKeyword ::= REC | TRUE | FALSE | SWITCH | IF | ELSE
                      | ASYNC | AWAIT | TRY | CATCH | WHILE | FOR | AND | AS
private literal     ::= BIGINT | INT | FLOAT | StringLiteral | TemplateLiteral | REGEX
private comparisonOperator  ::= EQEQ | EQEQEQ | BANGEQ | BANGEQEQ | LT | GT | LTEQ | GTEQ
private logicalOperator     ::= AMPAMP | PIPEPIPE
private bitwiseOperator     ::= AMPAMPAMP | PIPEPIPEPIPE | CARETCARETCARET | TILDETILDETILDE
                              | SHIFT_LEFT | SHIFT_RIGHT | SHIFT_RIGHT_UNSIGNED
private arithmeticOperator  ::= PLUS | MINUS | STAR | SLASH | STARSTAR
                              | PLUS_DOT | MINUS_DOT | STAR_DOT | SLASH_DOT
private anyOperator         ::= EQ | comparisonOperator | logicalOperator | bitwiseOperator
                              | arithmeticOperator | ARROW | FAT_ARROW | PIPE_FORWARD | COLONGT | DOTDOT
private punctuation ::= COMMA | SEMICOLON | COLON | DOT | DOTDOTDOT
                      | TILDE | PIPE | UNDERSCORE | BANG | QUESTION | HASH | TICK | PCT
private comment     ::= LINE_COMMENT | BLOCK_COMMENT

// =============================================================================
// Let binding: binding pattern and expression
//
// LetBinding splits at the top-level '=' into:
//   - LetBindingPattern: the binding pattern (left of '=') — public PSI node
//   - Expr: the value expression (right of '=') — public PSI node, opaque for now
//
// In ReScript, '=' never appears inside a binding pattern (no default values
// in record destructuring like JS), so the first '=' is always the boundary.
// =============================================================================

LetBindingPattern ::= letBindingPatternToken+
private letBindingPatternToken ::= delimitedBlock | letBindingPatternAtom

// Like nonDeclToken but without EQ (EQ is the pattern/expr boundary)
private letBindingPatternAtom ::= exprKeyword | LIDENT | UIDENT | literal
                                | comparisonOperator | logicalOperator | bitwiseOperator
                                | arithmeticOperator | ARROW | FAT_ARROW | PIPE_FORWARD | COLONGT | DOTDOT
                                | punctuation | comment

// String literal: composite PSI node wrapping string tokens.
// Required for language injection (PsiLanguageInjectionHost).
StringLiteral ::= STRING_START (STRING_CONTENT | STRING_ESCAPE)* STRING_END {
    pin = 1
    mixin="com.github.benjamin_thomas.intellij_rescript.lang.psi.impl.ReScriptStringLiteralMixin"
    implements="com.intellij.psi.PsiLanguageInjectionHost"
}
// Template literal: composite PSI node wrapping template string tokens.
// Same purpose as StringLiteral but for backtick-delimited strings.
TemplateLiteral ::= TEMPLATE_START TEMPLATE_CONTENT* TEMPLATE_END {
    pin = 1
    mixin="com.github.benjamin_thomas.intellij_rescript.lang.psi.impl.ReScriptTemplateLiteralMixin"
    implements="com.intellij.psi.PsiLanguageInjectionHost"
}

// Expression: public node, opaque internals (same tokens as opaqueBody)
Expr ::= (delimitedBlock | nonDeclToken)+
